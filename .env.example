DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN
GUILD_ID=YOUR_GUILD_ID
BOT_DATA_DIR=./data
DB_PATH=welcome-db.json
# Database backend: "json" (default) or "sqlite". The sqlite backend writes only
# changed rows (incremental) instead of rewriting the whole db file on every flush,
# and stores `sot` split per-subkey so e.g. an antiteam ticket change touches ~50KB
# instead of the multi-MB blob. Requires Node >= 22.5 (built-in node:sqlite); falls
# back to json with a warning if unavailable. To enable safely:
#   1) node scripts/migrate-db-to-sqlite.js   (writes + verifies <DB_PATH>.sqlite)
#   2) set MODERATOR_DB_BACKEND=sqlite and restart
# The JSON file is kept untouched as a pre-migration backup; rolling back after the
# bot has written to sqlite needs `npm run export:db-json` first.
MODERATOR_DB_BACKEND=json
# Optional override for the sqlite file path (defaults to DB_PATH with .json->.sqlite).
SQLITE_DB_PATH=
CONFIG_PATH=./bot.config.json
VERIFICATION_ENABLED=false
